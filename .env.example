# Variables de entorno — Snag
# Copia este archivo como .env en el backend y como frontend/.env.local
# NUNCA subas tus archivos .env reales al repositorio

# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
# SQLite (desarrollo local, sin configuración):
# DATABASE_URL=sqlite+aiosqlite:///./snag.db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Proveedor de IA ───────────────────────────────────────────────────────────
AI_PROVIDER=zai
AI_API_KEY=your_ai_api_key_here
AI_MODEL=glm-4.5-flash
AI_ENDPOINT=https://api.z.ai/api/paas/v4

# ── Seguridad / JWT ───────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here   # genera con: openssl rand -hex 32

# ── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_URL=http://localhost:8000/api/v1

# ── GitHub OAuth (https://github.com/settings/developers) ────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
